<Window x:Class="MessageApp.ChatsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MessageApp"
        mc:Ignorable="d"
        Title="ChatsWindow" Height="450" Width="800">
    <Grid>
         <StackPanel Margin="20">

        <TextBox x:Name="ChatNameBox"
                 Height="30"
                 Margin="0 5"/>

        <Button Content="Create Chat"
                Height="30"
                Margin="0 5"
                Click="CreateChat_Click"/>

        <ListBox x:Name="ChatsList"
                 Height="250"
                 DisplayMemberPath="Name"/>

    </StackPanel>
    </Grid>
</Window>
