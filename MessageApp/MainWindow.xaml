<Window x:Class="MessageApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MessageApp"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="550"
        Background="#1E1E2E">
    <Window.Resources>
        <SolidColorBrush x:Key="CardBrush" Color="#2D2D3A"/>
        <SolidColorBrush x:Key="InputBrush" Color="#3D3D4A"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#7C4DFF"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#A0A0B0"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="#FF6B6B"/>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="#4A4A5A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimary}"/>
        </Style>
        
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="#4A4A5A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimary}"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Resources>
    <Grid>
        <StackPanel Margin="30">

            <Border Height="80" Background="#EEE" CornerRadius="10" Margin="0 0 0 15">
                <Image Source="Images/unnamed.png"
           Stretch="Uniform"
           HorizontalAlignment="Center"
           VerticalAlignment="Center"/>
            </Border>

            <TextBlock Text="Login"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="0 0 0 10"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="Login"/>
            <TextBox x:Name="LoginBox" Height="30" Margin="0 5 0 10"/>

            <TextBlock Text="Password"/>
            <PasswordBox x:Name="PasswordBox" Height="30" Margin="0 5 0 15"/>

            <Button Content="Login"
                    Height="35"
                    Click="Login_Click"
                    Margin="0 5"/>

            <Button Content="Register"
                    Height="35"
                    Click="OpenRegister_Click"
                    Margin="0 5"/>

            <TextBlock x:Name="ErrorText"
                       Foreground="Red"
                       TextAlignment="Center"
                       Margin="0 10 0 0"/>

        </StackPanel>
    </Grid>
</Window>
