<Window x:Class="MessageApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MessageApp"
        mc:Ignorable="d"
        Title="MainWindow" Height="350" Width="350">
    <Grid>
        <StackPanel Margin="30">

            <Border Height="80" Background="#EEE" CornerRadius="10" Margin="0 0 0 15">
                <Image Source="Images/unnamed.png"
           Stretch="Uniform"
           HorizontalAlignment="Center"
           VerticalAlignment="Center"/>
            </Border>

            <TextBlock Text="Login"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="0 0 0 10"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="Login"/>
            <TextBox x:Name="LoginBox" Height="30" Margin="0 5 0 10"/>

            <TextBlock Text="Password"/>
            <PasswordBox x:Name="PasswordBox" Height="30" Margin="0 5 0 15"/>

            <Button Content="Login"
                    Height="35"
                    Click="Login_Click"
                    Margin="0 5"/>

            <Button Content="Register"
                    Height="35"
                    Click="OpenRegister_Click"
                    Margin="0 5"/>

            <TextBlock x:Name="ErrorText"
                       Foreground="Red"
                       TextAlignment="Center"
                       Margin="0 10 0 0"/>

        </StackPanel>
    </Grid>
</Window>
