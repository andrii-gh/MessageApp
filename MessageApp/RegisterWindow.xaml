<Window x:Class="MessageApp.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MessageApp"
        mc:Ignorable="d"
        Title="RegisterWindow" Height="250" Width="300">
    <Grid>
        <StackPanel Margin="20">
            <Label Content="Login"/>
            <TextBox x:Name="LoginBox" Margin="0 5"/>
            <Label Content="Password"/>
            <PasswordBox x:Name="PasswordBox" Margin="0 5"/>

            <Button Content="Register" Click="Register_Click" Margin="0 5"/>

            <TextBlock x:Name="ErrorText" Foreground="Red"/>
        </StackPanel>
    </Grid>
</Window>
