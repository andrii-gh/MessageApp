<Window x:Class="MessageApp.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MessageApp"
        mc:Ignorable="d"
        Title="RegisterWindow" Height="300" Width="400"
        Background="#1E1E2E">
    <Window.Resources>
        <SolidColorBrush x:Key="CardBrush" Color="#2D2D3A"/>
        <SolidColorBrush x:Key="InputBrush" Color="#3D3D4A"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#7C4DFF"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#A0A0B0"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="#FF6B6B"/>
        

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="#4A4A5A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimary}"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="#4A4A5A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimary}"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Resources>
    <Grid>
        <StackPanel Margin="20">
            <Label Content="Login"/>
            <TextBox x:Name="LoginBox" Margin="0 5"/>
            <Label Content="Password"/>
            <PasswordBox x:Name="PasswordBox" Margin="0 5"/>

            <Button Content="Register" Click="Register_Click" Margin="0 5"/>

            <TextBlock x:Name="ErrorText" Foreground="Red"/>
        </StackPanel>
    </Grid>
</Window>
