<Window x:Class="MessageApp.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MessageApp"
        mc:Ignorable="d"
        Background="#1E1E2E"
        Title="SettingsWindow" Height="550" Width="400">

    <Window.Resources>
        <SolidColorBrush x:Key="CardBrush" Color="#2D2D3A"/>
        <SolidColorBrush x:Key="InputBrush" Color="#3D3D4A"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#7C4DFF"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#A0A0B0"/>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="#4A4A5A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimary}"/>
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A4A5A"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Width" Value="90"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Profile Settings" FontSize="22" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,25"
                   Foreground="{StaticResource TextPrimary}"/>

        <Border Grid.Row="1" Width="110" Height="110" CornerRadius="55" 
                Background="{StaticResource CardBrush}" 
                HorizontalAlignment="Center" Margin="0,0,0,15">
            <Image x:Name="ProfileAvatar" Stretch="UniformToFill" Width="100" Height="100"/>
        </Border>

        <Button Grid.Row="2" Content="📁 Choose Avatar" Click="ChooseAvatar_Click" 
                Width="140" Height="34" HorizontalAlignment="Center" Margin="0,5,0,20"
                Background="{StaticResource AccentBrush}" Foreground="White" 
                BorderThickness="0" Cursor="Hand"/>

        <TextBlock Grid.Row="3" Text="USERNAME" FontSize="12" 
                   Foreground="{StaticResource TextSecondary}" Margin="0,10,0,5"/>
        <TextBox x:Name="NicknameBox" Grid.Row="4" Margin="0,0,0,15"/>

        <TextBlock Grid.Row="5" Text="BIRTH DATE" FontSize="12" 
                   Foreground="{StaticResource TextSecondary}" Margin="0,5,0,5"/>
        <DatePicker x:Name="BirthDatePicker" Grid.Row="6" Height="35" Margin="0,5,0,25"/>

        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
            <Button Content="💾 Save" Click="Save_Click" Width="100" Margin="0,0,15,0"
                    Background="{StaticResource AccentBrush}" Foreground="White" BorderThickness="0"/>
            <Button Content="✖ Cancel" Click="Cancel_Click" Width="100"
                    Background="{StaticResource CardBrush}" Foreground="{StaticResource TextPrimary}" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
