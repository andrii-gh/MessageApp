<Window x:Class="MessageApp.HomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Messenger" Height="600" Width="900"
        Background="#1E1E2E">

    <Window.Resources>
        <SolidColorBrush x:Key="SidebarBg" Color="#1A1A2A"/>
        <SolidColorBrush x:Key="CardBg" Color="#2D2D3A"/>
        <SolidColorBrush x:Key="InputBg" Color="#3D3D4A"/>
        <SolidColorBrush x:Key="Accent" Color="#7C4DFF"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#B0B0C0"/>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="#4A4A5A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimary}"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border x:Name="Sidebar" Background="#2D2D30">
            <StackPanel Margin="10 60 10 10">
                <Button Click="Profile_Click" Background="Transparent" BorderThickness="0" 
                        Cursor="Hand" HorizontalAlignment="Left" Margin="0,0,0,5">
                    <Border Width="40" Height="40" CornerRadius="20" Background="#7C4DFF">
                        <Image x:Name="AvatarImage" Width="36" Height="36" Stretch="UniformToFill"/>
                    </Border>
                </Button>

                <TextBlock Text="PROFILE" Foreground="White" FontSize="20" Margin="10"/>
                <TextBlock x:Name="LoginText" Foreground="White" FontSize="16" Margin="10"/>
                <TextBlock Text="Status: Online" Foreground="LightGreen" FontSize="14" Margin="10"/>

                <Button Content="Logout" Height="35" Margin="10" Click="Logout_Click" Background="#7C4DFF" Foreground="White"/>
                <Button Content="Create Chat" Height="35" Margin="10" Click="CreateChat_Click" Background="#7C4DFF" Foreground="White"/>
                <Button Content="Task Manager" Height="35" Margin="10" Click="OpenTaskManager_Click" Background="#7C4DFF" Foreground="White"/>

                <TextBox x:Name="SearchChatBox" Height="40" Margin="10" 
                         VerticalContentAlignment="Center" TextChanged="SearchChatBox_TextChanged"/>
                <TextBox x:Name="SearchMessageBox" Height="40" Margin="10" 
                         VerticalContentAlignment="Center" TextChanged="SearchMessageBox_TextChanged"/>

                <ListBox x:Name="ChatsList" Margin="10" Height="200" 
                         DisplayMemberPath="Name" SelectionChanged="ChatsList_SelectionChanged"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="60"/>
            </Grid.RowDefinitions>

            <TextBox x:Name="ChatBox" Margin="5" IsReadOnly="True" 
                     TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                     Background="#2D2D3A" Foreground="White"/>

            <TextBlock x:Name="LoadingText" Text="Loading..." Foreground="White" 
                       Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,10,0,0"/>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5">
                <TextBox x:Name="MsgBox" Width="500" Height="35" Margin="5"/>
                <Button Content="Send" Width="100" Height="35" Margin="5" 
                        Click="Send_Click" Background="#7C4DFF" Foreground="White"/>
            </StackPanel>
        </Grid>

        <!-- Кнопка відкриття меню (видима коли Sidebar прихований) -->
        <Button x:Name="OpenMenuButton"
                Content="☰"
                Width="40"
                Height="40"
                FontSize="20"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="5"
                Visibility="Collapsed"
                Click="Menu_Click"
                Background="#7C4DFF"
                Foreground="White"/>
    </Grid>
</Window>