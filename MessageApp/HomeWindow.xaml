<Window x:Class="MessageApp.HomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MessageApp"
        mc:Ignorable="d"
        Title="Messenger" Height="500" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border x:Name="Sidebar"
                Background="#2D2D30">

            <Grid>

                <Button Content="☰"
                        Width="40"
                        Height="40"
                        FontSize="20"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="5"
                        Click="Menu_Click"/>

                <StackPanel Margin="10 60 10 10">

                    <TextBlock Text="PROFILE"
                               Foreground="White"
                               FontSize="20"
                               Margin="10"/>

                    <TextBlock x:Name="LoginText"
                               Foreground="White"
                               FontSize="16"
                               Margin="10"/>

                    <TextBlock Text="Status: Online"
                               Foreground="LightGreen"
                               FontSize="14"
                               Margin="10"/>

                    <Button Content="Logout"
                            Height="35"
                            Margin="10"
                            Click="Logout_Click"/>
                </StackPanel>

            </Grid>
        </Border>

        <Grid Grid.Column="1">

            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition Height="60"/>
            </Grid.RowDefinitions>

            <TextBox x:Name="ChatBox"
                     Margin="5"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"/>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        Margin="5">

                <TextBox x:Name="MsgBox"
                         Width="500"
                         Height="35"
                         Margin="5"/>

                <Button Content="Send"
                        Width="100"
                        Height="35"
                        Margin="5"
                        Click="Send_Click"/>
            </StackPanel>

            <Button x:Name="OpenMenuButton"
                    Content="☰"
                    Width="40"
                    Height="40"
                    FontSize="20"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="5"
                    Visibility="Collapsed"
                    Click="Menu_Click"/>
        </Grid>
    </Grid>
</Window>