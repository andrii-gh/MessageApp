<Window x:Class="MessageApp.HomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MessageApp"
        mc:Ignorable="d"
        Title="HomeWindow" Height="200" Width="300">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>


        <TextBox x:Name="ChatBox"
             IsReadOnly="True"
             TextWrapping="Wrap"
             Margin="5"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal">
            <TextBox x:Name="MsgBox" Width="300" Margin="5"/>
            <Button Content="Send" Click="Send_Click"/>
        </StackPanel>
    </Grid>
    </Window>